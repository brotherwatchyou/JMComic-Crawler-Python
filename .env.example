# JMComic Docker 环境变量配置
# 复制此文件为 .env 后修改：cp .env.example .env

# 数据目录（SQLite数据库、配置文件）
JM_DATA_DIR=/data

# 漫画下载目录
JM_DOWNLOAD_DIR=/downloads

# WebUI 端口
JM_WEBUI_PORT=9801

# WebUI 访问密码（留空则不启用密码保护）
JM_WEBUI_PASSWORD=

# 自定义配置文件路径（可选，默认使用内置 option_docker.yml）
JM_OPTION_PATH=/app/assets/option/option_docker.yml
